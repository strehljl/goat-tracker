generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   FarmMembership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Farm {
  id             String           @id @default(cuid())
  name           String
  imageUrl       String?
  joinCode       String           @unique @default(cuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  members        FarmMembership[]
  animals        Animal[]
  herds          Herd[]
  locations      FarmLocation[]
  breedingEvents BreedingEvent[]
  expenses       Expense[]
  sales          Sale[]
  vaccinations   Vaccination[]
  medications    Medication[]
  vetVisits      VetVisit[]
  dewormings     Deworming[]
  healthNotes    HealthNote[]
}

// A named herd within a farm — each herd tracks one animal type
model Herd {
  id          String     @id @default(cuid())
  farmId      String
  name        String
  animalType  AnimalType @default(GOAT)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  farm        Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animals     Animal[]

  @@unique([farmId, name])
  @@index([farmId])
}

model FarmLocation {
  id        String   @id @default(cuid())
  farmId    String
  name      String
  createdAt DateTime @default(now())
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animals   Animal[]

  @@unique([farmId, name])
  @@index([farmId])
}

model FarmMembership {
  id        String   @id @default(cuid())
  farmId    String
  userId    String
  isOwner   Boolean  @default(false)
  createdAt DateTime @default(now())
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([farmId, userId])
  @@index([userId])
  @@index([farmId])
}

model Animal {
  id                  String          @id @default(cuid())
  farmId              String?
  herdId              String?
  name                String
  tagId               String
  breed               String?
  dateOfBirth         DateTime?
  gender              AnimalGender
  colorMarkings       String?
  photoUrl            String?
  purchaseDate        DateTime?
  purchasePrice       Decimal?        @db.Decimal(10, 2)
  damId               String?
  sireId              String?
  locationId          String?
  status              AnimalStatus    @default(ACTIVE)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  farm                Farm?           @relation(fields: [farmId], references: [id])
  herd                Herd?           @relation(fields: [herdId], references: [id], onDelete: SetNull)
  location            FarmLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  breedingAsMale      BreedingEvent[] @relation("MaleBreeding")
  breedingAsFemale    BreedingEvent[] @relation("FemaleBreeding")
  dewormings          Deworming[]
  expenses            Expense[]
  dam                 Animal?         @relation("DamOffspring", fields: [damId], references: [id])
  damOffspring        Animal[]        @relation("DamOffspring")
  sire                Animal?         @relation("SireOffspring", fields: [sireId], references: [id])
  sireOffspring       Animal[]        @relation("SireOffspring")
  healthNotes         HealthNote[]
  offspring           Offspring?
  medications         Medication[]
  sale                Sale?
  vaccinations        Vaccination[]
  vetVisits           VetVisit[]

  @@unique([farmId, tagId])
  @@index([farmId])
  @@index([herdId])
  @@index([status])
  @@index([gender])
  @@index([damId])
  @@index([sireId])
  @@index([locationId])
  @@index([dateOfBirth])
}

model Vaccination {
  id          String    @id @default(cuid())
  farmId      String?
  animalId    String
  name        String
  dateGiven   DateTime
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  farm        Farm?     @relation(fields: [farmId], references: [id])
  animal      Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([animalId])
  @@index([nextDueDate])
  @@index([farmId, nextDueDate])
}

model Medication {
  id        String    @id @default(cuid())
  farmId    String?
  animalId  String
  name      String
  dosage    String?
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  farm      Farm?     @relation(fields: [farmId], references: [id])
  animal    Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([animalId])
}

model VetVisit {
  id        String   @id @default(cuid())
  farmId    String?
  animalId  String
  date      DateTime
  reason    String
  diagnosis String?
  treatment String?
  cost      Decimal? @db.Decimal(10, 2)
  vetName   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm?    @relation(fields: [farmId], references: [id])
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([animalId])
}

model Deworming {
  id          String    @id @default(cuid())
  farmId      String?
  animalId    String
  productName String
  dateGiven   DateTime
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  farm        Farm?     @relation(fields: [farmId], references: [id])
  animal      Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([animalId])
  @@index([nextDueDate])
  @@index([farmId, nextDueDate])
}

model HealthNote {
  id        String   @id @default(cuid())
  farmId    String?
  animalId  String
  date      DateTime
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm?    @relation(fields: [farmId], references: [id])
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([animalId])
}

model BreedingEvent {
  id              String        @id @default(cuid())
  farmId          String?
  parentFemaleId  String
  parentMaleId    String
  breedingDate    DateTime
  expectedDueDate DateTime?
  status          BreedingStatus @default(PENDING)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  farm            Farm?          @relation(fields: [farmId], references: [id])
  parentMale      Animal         @relation("MaleBreeding", fields: [parentMaleId], references: [id])
  parentFemale    Animal         @relation("FemaleBreeding", fields: [parentFemaleId], references: [id])
  birthRecord     BirthRecord?

  @@index([farmId])
  @@index([status])
  @@index([parentFemaleId])
  @@index([parentMaleId])
  @@index([expectedDueDate])
}

model BirthRecord {
  id              String        @id @default(cuid())
  breedingEventId String        @unique
  birthDate       DateTime
  complications   String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  offspring       Offspring[]
  breedingEvent   BreedingEvent @relation(fields: [breedingEventId], references: [id], onDelete: Cascade)
}

model Offspring {
  id            String       @id @default(cuid())
  birthRecordId String
  animalId      String?      @unique
  gender        AnimalGender
  birthWeight   Decimal?     @db.Decimal(5, 2)
  status        OffspringStatus @default(ALIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  animal        Animal?      @relation(fields: [animalId], references: [id])
  birthRecord   BirthRecord  @relation(fields: [birthRecordId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String          @id @default(cuid())
  farmId      String?
  animalId    String?
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  vendorName  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  farm        Farm?           @relation(fields: [farmId], references: [id])
  animal      Animal?         @relation(fields: [animalId], references: [id])

  @@index([farmId])
  @@index([animalId])
  @@index([date])
  @@index([category])
  @@index([farmId, category])
}

model Sale {
  id           String   @id @default(cuid())
  farmId       String?
  animalId     String   @unique
  saleDate     DateTime
  salePrice    Decimal  @db.Decimal(10, 2)
  buyerName    String?
  buyerContact String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  farm         Farm?    @relation(fields: [farmId], references: [id])
  animal       Animal   @relation(fields: [animalId], references: [id])

  @@index([farmId])
  @@index([saleDate])
}

enum AnimalType {
  GOAT
  SHEEP
  CATTLE
  PIG
  ALPACA
  OTHER
}

enum AnimalGender {
  FEMALE
  MALE
  NEUTERED_MALE
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DECEASED
}

enum BreedingStatus {
  PENDING
  CONFIRMED
  FAILED
  DELIVERED
}

enum OffspringStatus {
  ALIVE
  STILLBORN
}

enum ExpenseCategory {
  FEED
  MEDICAL
  PURCHASE
  EQUIPMENT
  OTHER
}
